#!/bin/sh
# toggle <park|close> <app-id> [command...]
# Scratchpad / raise-or-run-style toggle for a single floating window, keyed by
# app-id (footclient windows share one PID via the foot server, so pgrep can't
# tell them apart). Behaviour by the current state of the <app-id> window:
#   not running          -> spawn [command...] (nothing if no command given)
#   on another workspace -> summon to the current workspace, float, focus
#   here but not focused -> focus (raise)
#   here and focused     -> hide it, per mode:
#                             park  -> park on the "scratch" workspace
#                             close -> close the window (re-spawned next time)
mode=$1
app_id=$2
shift 2

case "$mode" in
    park|close) ;;
    *) echo "toggle: unknown mode '$mode' (use park|close)" >&2; exit 1 ;;
esac

win=$(niri msg --json windows | jq -c --arg a "$app_id" \
    '[.[] | select(.app_id == $a)] | .[0] // empty')

if [ -z "$win" ]; then
    [ "$#" -gt 0 ] && exec "$@"   # not running -> spawn it (if a command was given)
    exit 0
fi

id=$(printf '%s' "$win" | jq -r '.id')
win_ws=$(printf '%s' "$win" | jq -r '.workspace_id')
focused=$(printf '%s' "$win" | jq -r '.is_focused')

cur=$(niri msg --json workspaces | jq -c '[.[] | select(.is_focused)] | .[0]')
cur_id=$(printf '%s' "$cur" | jq -r '.id')
cur_idx=$(printf '%s' "$cur" | jq -r '.idx')

if [ "$win_ws" != "$cur_id" ]; then
    niri msg action move-window-to-workspace --window-id "$id" --focus true "$cur_idx"
    niri msg action move-window-to-floating --id "$id"
    niri msg action focus-window --id "$id"
elif [ "$focused" != "true" ]; then
    niri msg action focus-window --id "$id"
elif [ "$mode" = "park" ]; then
    niri msg action move-window-to-workspace --window-id "$id" --focus false "scratch"
else
    niri msg action close-window --id "$id"
fi
