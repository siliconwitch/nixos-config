#!/bin/sh
# raise-or-run <app-id> <command...>
# Focus an existing window with the given app-id, or spawn <command> if none.
# Lets niri binds be single-instance: repeated keypresses refocus instead of
# stacking duplicate windows. app_id is the only reliable key here because all
# footclient windows share one PID (the foot server), so pgrep/flock can't tell
# them apart.
app_id=$1
shift

id=$(niri msg --json windows | jq -r --arg a "$app_id" \
    '[.[] | select(.app_id == $a)] | sort_by(.id) | .[0].id // empty')

if [ -n "$id" ]; then
    exec niri msg action focus-window --id "$id"
else
    exec "$@"
fi
