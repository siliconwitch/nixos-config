#!/bin/sh
# udev -> ac-event.service, on every ADP0 (AC adapter) change. Runs as root, no session.
# Watch:  journalctl -fu ac-event
# Test:   sudo udevadm trigger -c change /sys/class/power_supply/ADP0
online=$(cat /sys/class/power_supply/ADP0/online)   # 1 = plugged in, 0 = on battery

echo "ac-event: online=$online"

# ---- tinker below ----------------------------------------------------------
# Root has no session, so to reach your notifications become your user + bus:
#   runuser -u raj -- env XDG_RUNTIME_DIR=/run/user/1000 notify-send "AC" "online=$online"
