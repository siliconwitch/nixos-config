#!/bin/sh
# scratch-toggle <app-id>
# Scratchpad-style show/hide for a floating window. Hidden windows are parked on
# the "scratch" workspace; showing brings the window to the current workspace as
# a floating, focused window. niri 26.04 has no native scratchpad, so this moves
# the window between the current workspace and the dedicated "scratch" one.
#   - hidden (on another workspace) -> summon here, float, focus
#   - here but not focused          -> focus it (raise)
#   - here and focused              -> hide back to scratch (focus stays put)
app_id="$1"

win=$(niri msg --json windows | jq -c --arg a "$app_id" \
    '[.[] | select(.app_id == $a)] | .[0] // empty')
[ -z "$win" ] && exit 0   # not running (started at boot); nothing to toggle

id=$(printf '%s' "$win" | jq -r '.id')
win_ws=$(printf '%s' "$win" | jq -r '.workspace_id')
focused=$(printf '%s' "$win" | jq -r '.is_focused')

cur=$(niri msg --json workspaces | jq -r '[.[] | select(.is_focused)] | .[0]')
cur_id=$(printf '%s' "$cur" | jq -r '.id')
cur_idx=$(printf '%s' "$cur" | jq -r '.idx')

if [ "$win_ws" = "$cur_id" ]; then
    if [ "$focused" = "true" ]; then
        niri msg action move-window-to-workspace --window-id "$id" --focus false "scratch"
    else
        niri msg action focus-window --id "$id"
    fi
else
    niri msg action move-window-to-workspace --window-id "$id" --focus true "$cur_idx"
    niri msg action move-window-to-floating --id "$id"
    niri msg action focus-window --id "$id"
fi
