spawn-sh-at-startup "mako"
spawn-sh-at-startup "foot --server"
spawn-sh-at-startup "swaybg -i ~/.config/wallpaper.jpg"
spawn-sh-at-startup "~/projects/launtui/launtui --watch"
spawn-sh-at-startup "chromium --app=https://music.youtube.com"
spawn-sh-at-startup "chromium --app=https://discord.com/app"
spawn-sh-at-startup "foot --app-id=scratch.yazi -o colors-dark.alpha=0.85 yazi"

workspace "scratch" // Parking space for "minimised" apps such as Discord; declared first so it sits above main
workspace "main"
spawn-sh-at-startup "sleep 1 && niri msg action focus-workspace main" // Switch to main after boot

binds {
    // Launcher & shortcuts
    Mod+Space                 hotkey-overlay-title="Launcher"                     { spawn-sh "~/.config/scripts/toggle close foot.launcher footclient --app-id=foot.launcher -o colors-dark.alpha=0.85 -e ~/projects/launtui/launtui"; }
    Mod+T                     hotkey-overlay-title="Terminal"                     { spawn-sh "footclient -e sh -c 'fastfetch; exec $SHELL'"; }
    Mod+B                     hotkey-overlay-title="Browser"                      { spawn-sh "firefox"; }
    Mod+Y                     hotkey-overlay-title="YouTube Music"                { spawn-sh "~/.config/scripts/toggle park chrome-music.youtube.com__-Default chromium --app=https://music.youtube.com"; }
    Mod+D                     hotkey-overlay-title="Discord"                      { spawn-sh "~/.config/scripts/toggle park chrome-discord.com__app-Default chromium --app=https://discord.com/app"; }
    Mod+Shift+Y               hotkey-overlay-title="Files"                        { spawn-sh "~/.config/scripts/toggle park scratch.yazi foot --app-id=scratch.yazi -o colors-dark.alpha=0.85 yazi"; }
    Mod+Shift+M               hotkey-overlay-title="Mixer"                        { spawn-sh "~/.config/scripts/toggle close footclient.wiremix footclient --app-id=footclient.wiremix -o colors-dark.alpha=0.85 -e wiremix"; }
    Mod+Shift+N               hotkey-overlay-title="Network"                      { spawn-sh "~/.config/scripts/toggle close footclient.impala footclient --app-id=footclient.impala -o colors-dark.alpha=0.85 -e impala"; }
    Mod+Shift+B               hotkey-overlay-title="Bluetooth"                    { spawn-sh "~/.config/scripts/toggle close footclient.bluetui footclient --app-id=footclient.bluetui -o colors-dark.alpha=0.85 -e bluetui"; }

    // Navigation
    Mod+H                     hotkey-overlay-title="Navigate left"                { focus-column-left; }
    Mod+J                     hotkey-overlay-title="Navigate right"               { focus-window-or-workspace-down; }
    Mod+K                     hotkey-overlay-title="Navigate up"                  { focus-window-or-workspace-up; }
    Mod+L                     hotkey-overlay-title="Navigate down"                { focus-column-right; }

    Mod+Ctrl+H                hotkey-overlay-title="Navigate to left monitor"     { focus-monitor-right; }
    Mod+Ctrl+J                hotkey-overlay-title="Navigate to right monitor"    { focus-monitor-right; }

    Mod+1                                                                         { focus-workspace 1; }
    Mod+2                                                                         { focus-workspace 2; }
    Mod+3                                                                         { focus-workspace 3; }
    Mod+4                                                                         { focus-workspace 4; }
    Mod+5                                                                         { focus-workspace 5; }
    Mod+6                                                                         { focus-workspace 6; }
    Mod+7                                                                         { focus-workspace 7; }
    Mod+8                                                                         { focus-workspace 8; }
    Mod+9                                                                         { focus-workspace 9; }

    Mod+O                     hotkey-overlay-title="Overview" repeat=false        { toggle-overview; }

    // Window control
    Mod+Shift+H               hotkey-overlay-title="Move window left"             { move-column-left; }
    Mod+Shift+J               hotkey-overlay-title="Move window right"            { move-window-down-or-to-workspace-down; }
    Mod+Shift+K               hotkey-overlay-title="Move window up"               { move-window-up-or-to-workspace-up; }
    Mod+Shift+L               hotkey-overlay-title="Move window down"             { move-column-right; }

    Mod+Shift+Ctrl+H          hotkey-overlay-title="Move window to left monitor"  { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+L          hotkey-overlay-title="Move window to right monitor" { move-column-to-monitor-right; }

    Mod+Q                     hotkey-overlay-title="Close window" repeat=false    { close-window; }

    Mod+BracketLeft           hotkey-overlay-title="Merge window left"            { consume-or-expel-window-left; }
    Mod+BracketRight          hotkey-overlay-title="Merge window right"           { consume-or-expel-window-right; }
    Mod+Comma                 hotkey-overlay-title="Pull in left window"          { consume-window-into-column; }
    Mod+Period                hotkey-overlay-title="Push out window to left"      { expel-window-from-column; }

    Mod+R                     hotkey-overlay-title="Toggle width"                 { switch-preset-column-width; }
    Mod+Shift+R               hotkey-overlay-title="Toggle height"                { switch-preset-window-height; }
    Mod+F                     hotkey-overlay-title="Maximise screen"              { maximize-column; }
    Mod+Shift+F               hotkey-overlay-title="Full screen"                  { maximize-window-to-edges; }

    // Function keys
    Mod+XF86AudioMute         hotkey-overlay-title="Cycle audio output"           { spawn-sh "SINKS=$(pactl list short sinks | awk '{print $2}'); DEFAULT=$(pactl get-default-sink); NEXT=$(printf '%s\n' $SINKS | grep -A1 \"^$DEFAULT$\" | tail -1); { [ -z \"$NEXT\" ] || [ \"$NEXT\" = \"$DEFAULT\" ]; } && NEXT=$(printf '%s\n' $SINKS | head -1); pactl set-default-sink \"$NEXT\"; pactl list short sink-inputs | awk '{print $1}' | xargs -I{} pactl move-sink-input {} \"$NEXT\" 2>/dev/null; DESC=$(pactl list sinks | awk -v s=\"$NEXT\" '/Name:/{f=($2==s)} f && /Description:/{sub(/^[[:space:]]*Description:[[:space:]]*/,\"\"); print; exit}'); notify-send -h string:x-canonical-private-synchronous:audio-output 'Audio Output' \"$DESC\""; }
    XF86AudioRaiseVolume      allow-when-locked=true                              { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.025+ -l 1.0 && notify-send -h string:x-canonical-private-synchronous:volume -h int:value:$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{printf \"%d\", $2 * 100}') 'Volume' \"$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{printf \"%d%%\", $2 * 100}')\""; }
    XF86AudioLowerVolume      allow-when-locked=true                              { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.025- && notify-send -h string:x-canonical-private-synchronous:volume -h int:value:$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{printf \"%d\", $2 * 100}') 'Volume' \"$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{printf \"%d%%\", $2 * 100}')\""; }
    XF86AudioMute             allow-when-locked=true                              { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && notify-send -h string:x-canonical-private-synchronous:volume 'Volume' \"$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print ($3 == \"[MUTED]\") ? \"Muted\" : \"Unmuted\"}')\""; }
    XF86AudioMicMute          allow-when-locked=true                              { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }
    XF86AudioPlay             allow-when-locked=true                              { spawn-sh "playerctl play-pause"; }
    XF86AudioPrev             allow-when-locked=true                              { spawn-sh "playerctl previous"; }
    XF86AudioNext             allow-when-locked=true                              { spawn-sh "playerctl next"; }
    XF86MonBrightnessUp       allow-when-locked=true                              { spawn-sh "brightnessctl set 10%+ && VAL=$(( $(brightnessctl get) * 100 / $(brightnessctl max-brightness) )) && notify-send -h string:x-canonical-private-synchronous:brightness -h int:value:$VAL Brightness \"$VAL%\""; }
    XF86MonBrightnessDown     allow-when-locked=true                              { spawn-sh "brightnessctl set 10%- && VAL=$(( $(brightnessctl get) * 100 / $(brightnessctl max-brightness) )) && notify-send -h string:x-canonical-private-synchronous:brightness -h int:value:$VAL Brightness \"$VAL%\""; }

    // Screenshots
    Mod+Shift+3               hotkey-overlay-title="Screenshot"                   { screenshot-screen; }
    Mod+Shift+4               hotkey-overlay-title="Screenshot selection"         { screenshot; }
    Mod+Shift+5               hotkey-overlay-title="Screenshot window"            { screenshot-window; }

    // Other
    Mod+XF86ScreenSaver       hotkey-overlay-title="Lock the Screen"              { spawn-sh "hyprlock & sleep 2 && niri msg action power-off-monitors"; }
    Mod+Delete                hotkey-overlay-title="Lock the Screen"              { spawn-sh "hyprlock & sleep 2 && niri msg action power-off-monitors"; }
    Mod+Shift+Delete          allow-when-locked=true                              { spawn-sh "hyprlock"; }
    Mod+Shift+Slash           hotkey-overlay-title=null                           { show-hotkey-overlay; }
}

input {
    disable-power-key-handling
    focus-follows-mouse max-scroll-amount="50%"

    keyboard {
        xkb {
            layout "gb(mac)"
            options "caps:none"
        }
    }

    touchpad {
        natural-scroll
        scroll-factor 0.5 // Slower for GUI apps, but special rule below to speed up for terminal
    }
}

cursor {
    hide-when-typing
    hide-after-inactive-ms 5000
}

layout {
    gaps 12

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    preset-window-heights {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 3
        active-color "#fbb829"
        inactive-color "#5c6a72"
        urgent-color "#ef2f27"
    }

    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        color "#1c1b19"
    }
}

prefer-no-csd

window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
    draw-border-with-background false
}

// Speed up scrolling in terminals
window-rule {
    match app-id=r#"^(foot|scratch\.yazi)"#
    scroll-factor 2.0
}

// Small floating window for launcher
window-rule {
    match app-id="foot.launcher"
    open-floating true
    default-column-width { fixed 700; }
    default-window-height { fixed 450; }
}

// Medium floating window for bluetui, impala and wiremix  
window-rule {
    match app-id=r#"^footclient\."#
    open-floating true
    default-column-width { fixed 1000; }
    default-window-height { fixed 700; }
}

// Large floating window for apps such as Discord and Youtube Music
window-rule {
    match app-id=r#"^(scratch\.|chrome-music\.youtube\.com|chrome-discord\.com)"#
    open-floating true
    default-column-width { proportion 0.8; }
    default-window-height { proportion 0.8; }
}

// Park the large apps on the scratch workspace at startup
window-rule {
    match at-startup=true app-id=r#"^(scratch\.|chrome-music\.youtube\.com|chrome-discord\.com)"#
    open-on-workspace "scratch"
    open-focused false
}

hotkey-overlay {
    skip-at-startup
    hide-not-bound
}

gestures {
    hot-corners {
        off
    }
}

screenshot-path "~/downloads/%Y%m%d-screenshot-%H:%M:%S.png"

switch-events {
    lid-close { spawn "sh" "-c" "hyprlock --immediate-render --no-fade-in & niri msg output eDP-1 off; [ \"$(cat /sys/class/power_supply/ADP0/online)\" = 0 ] && systemctl suspend"; }
    lid-open  { spawn "niri" "msg" "output" "eDP-1" "on"; }
}
